# ==================== CHAOS .gitignore ====================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# PyInstaller build artifacts
build/
dist/
*.spec

# Compiled executables
*.exe

# Large media files
*.mp4
*.avi
*.mkv
*.mov

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Temporary files
*.tmp
*.bak
*.log

# Gesture config (auto-generated, keep empty template)
# chaos_gestures.json is fine to track

# Conversation history (local data, not for GitHub)
conversation_history.json

# Workspace user files (screenshots, personal notes)
workspace/screenshots/
